# --- PRIM API key (Île-de-France Mobilités) ---------------------------------
# Multi-user model: normally EACH client sends its own key via the
# 'X-PRIM-Api-Key' HTTP header. This variable is only an optional FALLBACK
# (handy for local dev, or as a default server-side key).
# Leave it empty on a shared public deployment.
#
# Get a free token at https://prim.iledefrance-mobilites.fr
# (My account -> Authentication tokens).
PRIM_API_KEY=

# --- OpenWeatherMap weather ---------------------------------------------------
# OpenWeatherMap requires a key. In the multi-user model, each client sends
# its own via the 'X-OpenWeather-Api-Key' header. This variable is the
# server-side FALLBACK (default key). Get a free key at
# https://openweathermap.org/api
OPENWEATHER_API_KEY=

# Weather cache duration in seconds (default 600 = 10 min).
# WEATHER_CACHE_TTL=600

# Optional: HTTP listening port (Render provides $PORT automatically).
# PORT=8000
